<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accountant Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <span>Welcome, <%= user.full_name %> (Accountant)</span>
    <a href="/logout">Logout</a>
  </nav>
  <div class="container dashboard-grid">
    <section class="card">
      <h1>Finance Dashboard</h1>
      <p>Manage invoices, reconcile accounts, and review payment trends.</p>
      <table>
        <thead><tr><th>Student</th><th>Email</th><th>Balance</th><th>Receipt</th><th>Action</th></tr></thead>
        <tbody>
          <% students.forEach(student => { %>
            <tr>
              <td><%= student.full_name %></td>
              <td><%= student.email %></td>
              <td>$<%= student.tuition_balance %></td>
              <td>
                <% if (student.tuition_receipt_file) { %>
                  <a href="/uploads/<%= student.tuition_receipt_file %>" target="_blank">View</a>
                <% } else { %>
                  None
                <% } %>
              </td>
              <td>
                <form action="/accountant/toggle-payment" method="POST">
                  <input type="hidden" name="student_id" value="<%= student.id %>">
                  <button type="submit">Approve / Revoke</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </section>
    <section class="card">
      <h2>Payment Summary</h2>
      <ul>
        <% payments.forEach(payment => { %><li><%= payment.payment_date %> — <%= payment.purpose %>: $<%= payment.amount %> (<%= payment.status %>)</li><% }); %>
      </ul>
    </section>
  </div>
</body>
</html>