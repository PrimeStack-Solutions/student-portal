<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Portal - Login</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container auth-card">
    <h1>University Student Information System</h1>
    <p>Secure access for applicants, students, administrators, and accountants.</p>
    <% if (error) { %><p class="error"><%= error %></p><% } %>
    <form action="/login" method="POST">
      <label for="username">Username or Student Number</label>
      <input type="text" id="username" name="username" required>
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required>
      <button type="submit">Login</button>
    </form>
    <div class="card" style="margin-top:16px;">
      <h2>Demo credentials</h2>
      <p><strong>Applicant:</strong> maya_applicant / password123</p>
      <p><strong>Student:</strong> john_student / password123</p>
      <p><strong>Student:</strong> jane_student / password123 (John Phiri)</p>
      <p><strong>Admin:</strong> alice_admin / password123</p>
      <p><strong>Accountant:</strong> bob_accountant / password123</p>
    </div>
    <div class="inline-links">
      <a href="/register">Create applicant account</a>
      <a href="/reset-password">Forgot password?</a>
    </div>
  </div>
</body>
</html>